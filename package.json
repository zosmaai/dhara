{
  "name": "@zosmaai/dhara",
  "version": "0.1.0",
  "description": "Minimal, secure, language-agnostic AI coding agent harness. Agent loop, extension protocol, 20+ LLM providers, session persistence, and TUI/REPL.",
  "type": "module",
  "keywords": [
    "coding-agent",
    "agent-harness",
    "protocol",
    "llm",
    "ai",
    "developer-tools",
    "extension",
    "json-rpc",
    "cli",
    "openai",
    "anthropic",
    "gemini",
    "tui",
    "terminal"
  ],
  "homepage": "https://github.com/zosmaai/dhara",
  "bugs": {
    "url": "https://github.com/zosmaai/dhara/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Zosma AI",
    "url": "https://zosma.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zosmaai/dhara.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dhara": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "spec",
    "README.md",
    "LICENSE",
    "LICENSE-SPEC.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fmt": "biome format --write .",
    "lint": "biome lint .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0"
  }
}

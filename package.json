{
  "name": "@zosmaai/dhara",
  "version": "0.1.0",
  "description": "The Agent Protocol Standard — minimal, secure, language-agnostic coding agent harness",
  "type": "module",
  "keywords": ["coding-agent", "agent-harness", "protocol", "llm", "ai", "developer-tools"],
  "homepage": "https://github.com/zosmaai/dhara",
  "bugs": {
    "url": "https://github.com/zosmaai/dhara/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Zosma AI",
    "url": "https://zosma.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zosmaai/dhara.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dhara": "./dist/cli/main.js"
  },
  "files": ["dist", "spec", "README.md", "LICENSE", "LICENSE-SPEC.md"],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fmt": "biome format --write .",
    "lint": "biome lint .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.19.18",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0"
  }
}

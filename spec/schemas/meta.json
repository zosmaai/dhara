{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zosma.ai/dhara/schemas/meta.json",
  "title": "Dhara Session Metadata",
  "description": "Schema for the session metadata file (meta.json). Contains session-level information that does not change with individual entries.",
  "type": "object",
  "required": ["formatVersion", "sessionId", "createdAt", "updatedAt", "cwd", "model"],
  "properties": {
    "formatVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the session format (e.g., '0.1.0')."
    },
    "sessionId": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v4 uniquely identifying this session."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of session creation."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last session modification."
    },
    "cwd": {
      "type": "string",
      "description": "Working directory at session start."
    },
    "model": {
      "$ref": "#/$defs/ModelRef",
      "description": "Active model for this session."
    },
    "extensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/ExtensionRef" },
      "description": "Extensions active during this session."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Arbitrary tags for categorizing the session."
    },
    "branchOf": {
      "type": ["string", "null"],
      "description": "If this session was forked from another, the source session ID."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ModelRef": {
      "type": "object",
      "required": ["id", "provider"],
      "properties": {
        "id": { "type": "string" },
        "provider": { "type": "string" },
        "thinkingLevel": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      },
      "additionalProperties": false
    },
    "ExtensionRef": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      },
      "additionalProperties": false
    }
  }
}

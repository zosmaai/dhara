{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zosma.ai/dhara/schemas/branch.json",
  "title": "Dhara Session Branch",
  "description": "Schema for branch entries in a Dhara session log. Branches mark fork points in the conversation tree.",
  "type": "object",
  "required": ["type", "id", "parentId", "timestamp"],
  "properties": {
    "type": {
      "const": "branch",
      "description": "Discriminator — this is a branch marker, not a session entry."
    },
    "id": {
      "type": "string",
      "description": "Unique branch identifier (e.g., 'b001')."
    },
    "parentId": {
      "type": "string",
      "description": "ID of the entry from which this branch diverges."
    },
    "label": {
      "type": "string",
      "description": "Human-readable branch name (e.g., 'try-different-approach')."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of branch creation."
    },
    "reason": {
      "type": "string",
      "enum": ["user_fork", "compaction", "model_switch", "error_recovery"],
      "description": "Why this branch was created."
    }
  },
  "additionalProperties": false
}
